# Database
# Format: mysql://user:password@host:port/dbname
DATABASE_URL=mysql://user:password@localhost:3306/cve_database

# NVD API key — get one at https://nvd.nist.gov/developers/request-an-api-key
# Without a key: 5 req/30s limit. With a key: 50 req/30s.
NVD_API_KEY=

# GitHub Personal Access Token — needs no special scopes (public advisory read is enough)
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# EUVD API key (optional — public access works without one)
EUVD_API_KEY=

# AI fallback — set to true to enable local CVSS prediction model
AI_FALLBACK_ENABLED=false

# App settings (optional)
DEBUG=false
LOG_LEVEL=INFO
WORKERS=4
HTTP_TIMEOUT=30.0
